{
  "name": "ai-workspace",
  "version": "1.1.0",
  "description": "Thread-based workspace management with specialized agents for long-running AI conversations",
  "author": {
    "name": "Sebastien Martin",
    "url": "https://github.com/sebmartin"
  },
  "repository": "https://github.com/sebmartin/ai-workspace-plugin",
  "license": "MIT",
  "mcpServers": {
    "threads": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--with", "mcp",
        "python3",
        "${CLAUDE_PLUGIN_ROOT}/skills/threads/scripts/mcp_server.py"
      ]
    }
  }
}
